# dear-blog 生产环境配置
# 使用前复制为 .env：cp .env.example .env
# .env 已加入 .gitignore，请勿提交到版本控制

# MySQL root 密码（自定义强密码）
DB_PASS=change_me_strong_password

# Redis 认证密码（自定义强密码）
REDIS_PASS=change_me_strong_password

# JWT 签名密钥（至少 32 位随机字符串，可用 openssl rand -hex 32 生成）
JWT_SECRET=change_me_at_least_32_chars_random_string
