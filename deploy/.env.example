# dear-blog production env template
# copy before use: cp .env.example .env

# backend image pushed by local/CI
# example: ghcr.io/your-org/dear-blog-backend:20260309-1a2b3c4
BACKEND_IMAGE=ghcr.io/your-org/dear-blog-backend:latest

# host port mapped to backend container 8080
BACKEND_PORT=18080

# MySQL root password
DB_PASS=change_me_strong_password

# Redis password
REDIS_PASS=change_me_strong_password

# JWT secret (at least 32 chars random string)
JWT_SECRET=change_me_at_least_32_chars_random_string
